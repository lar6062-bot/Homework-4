# --------------------------------------------------------------
#  LM Studio → OpenAI API (via http://localhost:1234/v1)
#  Model: "local-model"   (chat‑capable GPT model from LM Studio)
#  Prompts:
#      • "What are the different shot shapes in golf?"
#      • "What is a balance sheet?"
# --------------------------------------------------------------

import time
from openai import OpenAI

# 1️⃣ Create the client (no API key needed for LM Studio’s local token)
client = OpenAI(base_url="http://localhost:1234/v1", api_key="lm-studio")

# 2️⃣ The exact questions we want to ask
prompts = [
    "What are the different shot shapes in golf?",
    "What is a balance sheet?"
]

def run_experiment():
    for p in prompts:
        print(f"--- Processing Input: {p} ---")
        
        # 3️⃣ Call the local model (chat/completions endpoint)
        response = client.chat.completions.create(
            model="local-model",                     # LM Studio’s chat‑ready GPT‑style model
            messages=[{"role": "user", "content": p}],
            max_tokens=400,                          # generous enough for a clear answer
            temperature=0.7                         # mild randomness
        )
        
        # 4️⃣ Show the generated text
        print(f"RESPONSE:\n{response.choices[0].message.content}\n")
        
        # 5️⃣ Inspect token usage (useful for monitoring)
        usage = response.usage
        print("INSPECTION (Token Usage):")
        print(f"- Prompt Tokens: {usage.prompt_tokens}")
        print(f"- Completion Tokens: {usage.completion_tokens}")
        print(f"- Total Tokens: {usage.total_tokens}\n")
        
        # Small pause so LM Studio can keep up if you run the script fast
        time.sleep(0.5)

if __name__ == "__main__":
    run_experiment()
