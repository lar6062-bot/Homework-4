# --------------------------------------------------------------
#  LM Studio → OpenAI API (via http://localhost:1234/v1)
#  Model: "local-model"
#  Prompts:
#      • "what is better, chat gbt or gemini?"
#      • "why is florida hotter than pennsylvania"
# --------------------------------------------------------------

import time
from openai import OpenAI

# 1️⃣ Create the client – no API key needed for LM Studio (it uses a local token)
client = OpenAI(base_url="http://localhost:1234/v1", api_key="lm-studio")

# 2️⃣ The questions we want to ask
prompts = [
    "what is better, chat gbt or gemini?",
    "why is florida hotter than pennsylvania"
]

def run_experiment():
    for p in prompts:
        print(f"--- Processing Input: {p} ---")
        
        # 3️⃣ Call the local model (chat/completions endpoint)
        response = client.chat.completions.create(
            model="local-model",                     # LM Studio's chat‑capable model
            messages=[{"role": "user", "content": p}],
            max_tokens=500,                          # enough for a decent answer
            temperature=0.7                         # mild randomness
        )
        
        # 4️⃣ Print the generated text
        print(f"RESPONSE:\n{response.choices[0].message.content}\n")
        
        # 5️⃣ Print token usage (helpful for monitoring)
        usage = response.usage
        print("INSPECTION (Token Usage):")
        print(f"- Prompt Tokens: {usage.prompt_tokens}")
        print(f"- Completion Tokens: {usage.completion_tokens}")
        print(f"- Total Tokens: {usage.total_tokens}\n")
        
        # Small pause so LM Studio can keep up with rapid requests
        time.sleep(0.5)

if __name__ == "__main__":
    run_experiment()
